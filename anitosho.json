{
    "id": "anitosho",
    "name": "AniTosho",
    "version": "2.4.0",
    "language": "typescript",
    "type": "anime-torrent-provider",
    "description": "Older Version - Integrates Anime Tosho (NEW) as a torrent streaming provider for Seanime.",
    "author": "Faddix, Island, Thalkas",
    "icon": "https://raw.githubusercontent.com/Thalkas/owolowo/refs/heads/main/src/animetosho-new-logo.png",
    "lang": "multi",
    "userConfig": {
        "version": 1,
        "requiresConfig": false,
        "fields": [
            {
                "type": "text",
                "name": "jsonURL",
                "label": "Feed URL",
                "default": "https://animetosho.xyz/feed/json"
            },
            {
                "type": "text",
                "name": "maxPages",
                "label": "Max pages to fetch",
                "default": "3"
            }
        ]
    },
    "payloadURI": "https://raw.githubusercontent.com/Thalkas/owolowo/refs/heads/main/anitosho.ts",
    "manifestURI": "https://raw.githubusercontent.com/Thalkas/owolowo/refs/heads/main/anitosho.json"
}
